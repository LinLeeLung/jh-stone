rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: users can read/write their own document; admins can read/write all
    match /Users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role == 'admin');
      allow update: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role == 'admin')
                    // if role field is present, it must be one of the allowed values
                    && (!('role' in request.resource.data) ||
                        request.resource.data.role in ['admin','管理者','員工','客戶','遊客']);
      allow delete: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role == 'admin');
    }

    // Deny everything else by default - lock down the DB
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
