rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/Users/$(request.auth.uid));
    }

    function myRole() {
      return signedIn() ? userDoc().data.role : null;
    }

    function myCompanyId() {
      return signedIn() ? userDoc().data.companyId : null;
    }

    function isAdmin() {
      return signedIn() && myRole() == 'admin';
    }

    function isStaff() {
      return signedIn() && myRole() in ['admin', '管理者', '員工'];
    }

    // 行動角色：只能存取打卡/請假/加班（幫員工個人手機用帳號）
    function isMobileStaff() {
      return signedIn() && myRole() == '行動';
    }

    function isAdminOrManager() {
      return signedIn() && myRole() in ['admin', '管理者'];
    }

    function myStaffRole() {
      return signedIn() ? userDoc().data.staffRole : null;
    }

    function isLeaveApprover() {
      return signedIn() && (
        isAdminOrManager()
        || myStaffRole() in ['主管', 'HR']
      );
    }

    function myDept() {
      return signedIn() ? userDoc().data.dept : null;
    }

    function isApprovedCustomer() {
      return signedIn()
        && myRole() == '客戶'
        && userDoc().data.customerApproved == true
        && myCompanyId() != null
        && myCompanyId() != '';
    }

    function orderCompanyId(orderData) {
      return orderData.companyId;
    }

    function canReadOrder(orderId) {
      return isStaff()
        || (
          isApprovedCustomer()
          && orderCompanyId(
            get(/databases/$(database)/documents/Orders/$(orderId)).data
          ) == myCompanyId()
        );
    }

    // Users collection: users can read/write their own document; admins can read/write all
    match /Users/{userId} {
      allow create: if (
          request.auth != null
          && request.auth.uid == userId
          && request.resource.data.uid == request.auth.uid
          && (!('role' in request.resource.data) || request.resource.data.role == '遊客')
          && !('customerApproved' in request.resource.data)
          && !('companyId' in request.resource.data)
        ) || isAdmin();
      allow read: if signedIn() && (request.auth.uid == userId || isAdminOrManager() || isStaff() || isMobileStaff());
      allow update: if isAdminOrManager()
                    && (!('role' in request.resource.data) ||
                        request.resource.data.role in ['admin','管理者','員工','行動','客戶','遊客'])
                    || (
                      signedIn()
                      && request.auth.uid == userId
                      && request.resource.data.uid == resource.data.uid
                      && request.resource.data.role == resource.data.role
                      && request.resource.data.customerApproved == resource.data.customerApproved
                      && request.resource.data.companyId == resource.data.companyId
                    );
      allow delete: if signedIn() && (request.auth.uid == userId || isAdminOrManager());
    }

    // Orders documents may include internal fields; keep direct read staff-only.
    match /Orders/{orderId} {
      allow read: if isStaff();
      allow update: if isAdminOrManager();
      allow create, delete: if false;

      // completion photos metadata per order
      match /completionPhotos/{photoId} {
        allow read: if canReadOrder(orderId);
        allow create: if isStaff()
          && request.resource.data.uploadedByUid == request.auth.uid
          && request.resource.data.updatedByUid == request.auth.uid;
        allow update: if isStaff()
          && request.resource.data.updatedByUid == request.auth.uid
          && request.resource.data.uploadedByUid == resource.data.uploadedByUid;
        allow delete: if isStaff();
      }
    }

    // System settings (e.g. NAS path): staff can read (needed for punchLocation geofencing); only admin/manager can write
    // Exception: orderCounter can be written by any staff (needed for issueOrder transaction)
    match /SystemSettings/{docId} {
      allow read: if isStaff() || isMobileStaff();
      allow write: if isAdminOrManager();
    }
    match /SystemSettings/orderCounter {
      allow read, write: if isStaff();
    }

    // Client-side upload diagnostics for intermittent device/network issues.
    match /ClientUploadErrors/{logId} {
      allow create: if isStaff()
        && request.resource.data.uid == request.auth.uid;
      allow read: if isAdminOrManager();
      allow update, delete: if false;
    }

    // Server-side audit when 完工照片 fallback creates a NEW NAS folder
    // because PDF/folder-name search couldn't locate the order folder.
    // Written exclusively by Cloud Functions (admin SDK bypasses rules).
    match /CompletionPhotoFolderCreations/{docId} {
      allow read: if isAdminOrManager();
      allow create, update, delete: if false;
    }

    // Inventory color master used by 庫存查詢 UI.
    match /InventoryColors/{docId} {
      allow read, write: if isStaff();
    }

    // Pending (unscheduled) orders synced from Google Sheet.
    match /PendingOrders/{docId} {
      allow read: if isStaff();
      allow write: if false;
    }


    // Batch search progress (written by Cloud Function, read by staff)
    match /_system/{docId} {
      allow read: if isStaff();
      allow write: if false;
    }

    // Employee basic data: all staff can read (needed for order/install staff selectors); only admin/manager can write
    match /staff/{empNo} {
      allow read: if isStaff();
      allow write: if isAdminOrManager();
    }

    // Attendance (打卡): staff can create/read their own record;
    // admin/manager + leave approver(主管/HR) can read all for overtime review.
    match /attendance/{docId} {
      allow create: if isAdminOrManager()
        || ((isStaff() || isMobileStaff()) && request.resource.data.uid == request.auth.uid);
      allow update: if isAdminOrManager()
        || ((isStaff() || isMobileStaff()) && resource.data.uid == request.auth.uid);
      // resource == null when the doc doesn't exist yet; allow the read so getDoc returns "not found"
      allow read: if (isStaff() || isMobileStaff())
        && (resource == null || resource.data.uid == request.auth.uid || isLeaveApprover());
      allow delete: if isAdminOrManager();
    }

    // Attendance correction requests (忘記打卡補登): staff submit own;
    // admin/manager + approver(主管/HR) review and approve/reject.
    match /attendanceCorrectionRequests/{docId} {
      allow create: if (isStaff() || isMobileStaff())
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending';
      allow read: if isLeaveApprover()
        || ((isStaff() || isMobileStaff()) && resource.data.uid == request.auth.uid);
      allow update: if isLeaveApprover();
      allow delete: if (isStaff() || isMobileStaff())
        && resource.data.uid == request.auth.uid
        && resource.data.status == 'pending';
    }

    // Leave requests: staff submit own; admin/manager review all
    match /leaveRequests/{docId} {
      allow create: if (isStaff() || isMobileStaff())
        && request.resource.data.uid == request.auth.uid;
      // All staff can read so that 主管 and HR can load the pending queue;
      // 行動角色只能讀自己的請假單
      allow read: if isStaff()
        || (isMobileStaff() && resource.data.uid == request.auth.uid);
      allow update: if isStaff()
        || (isMobileStaff() && resource.data.uid == request.auth.uid);
      allow delete: if (isStaff() || isMobileStaff())
        && resource.data.uid == request.auth.uid
        && resource.data.status == 'pending';
    }

    // Overtime requests: same rules as leave requests
    match /overtimeRequests/{docId} {
      allow create: if (isStaff() || isMobileStaff())
        && request.resource.data.uid == request.auth.uid;
      // 行動角色只能讀自己的申請
      allow read: if isStaff()
        || (isMobileStaff() && resource.data.uid == request.auth.uid);
      allow update: if isStaff()
        || (isMobileStaff() && resource.data.uid == request.auth.uid);
      allow delete: if (isStaff() || isMobileStaff())
        && resource.data.uid == request.auth.uid
        && resource.data.status == 'pending';
    }

    // Leave quota: all staff can read; only admin/manager can write
    match /leaveQuota/{uid} {
      allow read: if isStaff() || (isMobileStaff() && request.auth.uid == uid);
      allow write: if isAdminOrManager();
    }

    // Payroll records: employee reads own; admin/manager reads all; write by admin only
    match /payroll/{docId} {
      allow read: if isStaff() && (
        isAdminOrManager() ||
        resource.data.uid == request.auth.uid
      );
      allow write: if isAdminOrManager();
    }

    // Loans: admin/manager full access; staff read own
    match /loans/{docId} {
      allow read: if isAdminOrManager()
                  || (isStaff() && resource.data.empNo != null);
      allow create, update, delete: if isAdminOrManager();
    }

    // 新 ERP 主檔：客戶資料、產品型號、石材狀態（所有員工可讀，admin/manager 可寫）
    match /customers/{docId} {
      allow read: if isStaff();
      allow write: if isAdminOrManager() || (isStaff() && myDept() == '1');
    }

    match /customerPricing/{docId} {
      allow read: if isStaff();
      allow write: if isAdminOrManager() || (isStaff() && myDept() == '1');
    }

    match /productModels/{docId} {
      allow read: if isStaff();
      allow write: if isAdminOrManager();
    }

    match /stoneStatus/{docId} {
      allow read: if isStaff();
      allow write: if isAdminOrManager();
    }

    // 銷售訂單（新 ERP）：員工可讀寫；admin/manager 可刪
    match /salesOrders/{docId} {
      allow read: if isStaff();
      allow create: if isStaff()
        && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isAdminOrManager()
        || (isStaff() && request.resource.data.updatedByUid == request.auth.uid);
      allow delete: if isAdminOrManager();

      match /drawings/{drawingId} {
        allow read: if isStaff();
        allow create: if isStaff()
          && request.resource.data.createdByUid == request.auth.uid;
        allow update: if isStaff()
          && request.resource.data.updatedByUid == request.auth.uid;
        allow delete: if isStaff();
      }

      match /confirmationDoc/{docId} {
        allow read: if isStaff();
        allow write: if isStaff()
          && request.resource.data.updatedByUid == request.auth.uid;
      }

      match /designFiles/{fileId} {
        allow read: if isStaff();
        allow create: if isStaff()
          && request.resource.data.uploadedByUid == request.auth.uid;
        allow delete: if isStaff();
      }

      match /samplePhotos/{fileId} {
        allow read: if isStaff();
        allow create: if isStaff()
          && request.resource.data.uploadedByUid == request.auth.uid;
        allow delete: if isStaff();
      }

      match /designReviewFiles/{fileId} {
        allow read: if isStaff();
        allow create: if isStaff()
          && request.resource.data.uploadedByUid == request.auth.uid;
        allow delete: if isStaff();
      }

      match /designReviewOverlays/{fileId} {
        allow read: if isStaff();
        allow create: if isStaff()
          && request.resource.data.uploadedByUid == request.auth.uid;
        allow delete: if isStaff();
      }
    }

    // Formal order number synchronization targets.
    match /productionJobs/{docId} {
      allow read: if isStaff();
      allow update: if isAdminOrManager();
      allow create, delete: if false;
    }

    match /repairTickets/{docId} {
      allow read: if isStaff();
      allow update: if isAdminOrManager();
      allow create, delete: if false;
    }

    match /dispatchEntries/{docId} {
      allow read: if isStaff();
      allow update: if isAdminOrManager();
      allow create, delete: if false;
    }

    // System configuration（路由權限等）：所有已登入員工可讀；只有 admin/manager 可寫
    match /Config/{docId} {
      allow read: if isStaff() || isMobileStaff();
      allow write: if isAdminOrManager();
    }

    // Deny everything else by default - lock down the DB
    match /{document=**} {
      allow read, write: if false;
    }

    // 圖章庫: 登入員工皆可讀取 shared 圖章; 作者可寫自己的
    match /stamps/{stampId} {
      allow read: if isStaff()
        && (resource.data.shared == true || resource.data.authorUid == request.auth.uid);
      allow create: if isStaff()
        && request.resource.data.authorUid == request.auth.uid;
      allow update: if isStaff()
        && resource.data.authorUid == request.auth.uid;
      allow delete: if isStaff()
        && resource.data.authorUid == request.auth.uid;
    }
  }
}
