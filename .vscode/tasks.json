{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build And Deploy Hosting",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"cd frontend && npm.cmd run build && cd .. && firebase deploy --only hosting"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Deploy Payroll Functions",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"firebase deploy --only functions:calculatePayroll,functions:autoCalculatePayroll --project jh-stone --non-interactive --config d:\\Data\\Desktop\\jh-stone\\firebase.json"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}
